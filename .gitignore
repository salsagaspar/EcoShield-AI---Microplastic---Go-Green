# =============================================================================
# EcoShield AI — .gitignore
# =============================================================================

# ── Python Virtual Environment ────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env

# ── Python Cache & Bytecode ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ── Jupyter Notebook Checkpoints ─────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Trained Model Files (large binaries) ─────────────────────────────────────
models/*.pkl
models/*.joblib
models/*.h5
models/*.pt
models/*.pth
models/*.onnx

# ── Raw & Cleaned Datasets (large CSVs) ──────────────────────────────────────
*.csv
data/processed/

# ── Dashboard JSON Data (auto-generated by script) ───────────────────────────
dashboard/data/*.json

# ── OS & Editor Files ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ── IDE & Tool Configs ────────────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace

# ── Build & Distribution ─────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/

# ── Logs & Temp Files ────────────────────────────────────────────────────────
*.log
*.tmp
*.temp
logs/

# ── Coverage & Testing ───────────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.tox/
